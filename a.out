:vpi_module "/usr/local/lib/ivl/v2009.vpi";
S_0x1dc971c0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x1dc97350 .scope module, "alu_tb" "alu_tb" 3 3;
 .timescale -9 -12;
v0x1dcab450_0 .var "A", 3 0;
v0x1dcab530_0 .var "B", 3 0;
v0x1dcab600_0 .net "carry", 0 0, v0x1dcab0d0_0;  1 drivers
v0x1dcab700_0 .net "result", 3 0, v0x1dcab1a0_0;  1 drivers
v0x1dcab7d0_0 .var "sel", 2 0;
S_0x1dc6f580 .scope module, "uut" "alu" 3 10, 4 1 0, S_0x1dc97350;
 .timescale 0 0;
    .port_info 0 /INPUT 4 "A";
    .port_info 1 /INPUT 4 "B";
    .port_info 2 /INPUT 3 "sel";
    .port_info 3 /OUTPUT 4 "result";
    .port_info 4 /OUTPUT 1 "carry";
v0x1dc6f760_0 .net "A", 3 0, v0x1dcab450_0;  1 drivers
v0x1dcaaff0_0 .net "B", 3 0, v0x1dcab530_0;  1 drivers
v0x1dcab0d0_0 .var "carry", 0 0;
v0x1dcab1a0_0 .var "result", 3 0;
v0x1dcab280_0 .net "sel", 2 0, v0x1dcab7d0_0;  1 drivers
E_0x1dc5e390 .event anyedge, v0x1dcab280_0, v0x1dc6f760_0, v0x1dcaaff0_0;
    .scope S_0x1dc6f580;
T_0 ;
    %wait E_0x1dc5e390;
    %load/vec4 v0x1dcab280_0;
    %dup/vec4;
    %pushi/vec4 0, 0, 3;
    %cmp/u;
    %jmp/1 T_0.0, 6;
    %dup/vec4;
    %pushi/vec4 1, 0, 3;
    %cmp/u;
    %jmp/1 T_0.1, 6;
    %dup/vec4;
    %pushi/vec4 2, 0, 3;
    %cmp/u;
    %jmp/1 T_0.2, 6;
    %dup/vec4;
    %pushi/vec4 3, 0, 3;
    %cmp/u;
    %jmp/1 T_0.3, 6;
    %dup/vec4;
    %pushi/vec4 4, 0, 3;
    %cmp/u;
    %jmp/1 T_0.4, 6;
    %pushi/vec4 0, 0, 4;
    %store/vec4 v0x1dcab1a0_0, 0, 4;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x1dcab0d0_0, 0, 1;
    %jmp T_0.6;
T_0.0 ;
    %load/vec4 v0x1dc6f760_0;
    %pad/u 5;
    %load/vec4 v0x1dcaaff0_0;
    %pad/u 5;
    %add;
    %split/vec4 4;
    %store/vec4 v0x1dcab1a0_0, 0, 4;
    %store/vec4 v0x1dcab0d0_0, 0, 1;
    %jmp T_0.6;
T_0.1 ;
    %load/vec4 v0x1dc6f760_0;
    %pad/u 5;
    %load/vec4 v0x1dcaaff0_0;
    %pad/u 5;
    %sub;
    %split/vec4 4;
    %store/vec4 v0x1dcab1a0_0, 0, 4;
    %store/vec4 v0x1dcab0d0_0, 0, 1;
    %jmp T_0.6;
T_0.2 ;
    %load/vec4 v0x1dc6f760_0;
    %load/vec4 v0x1dcaaff0_0;
    %and;
    %store/vec4 v0x1dcab1a0_0, 0, 4;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x1dcab0d0_0, 0, 1;
    %jmp T_0.6;
T_0.3 ;
    %load/vec4 v0x1dc6f760_0;
    %load/vec4 v0x1dcaaff0_0;
    %or;
    %store/vec4 v0x1dcab1a0_0, 0, 4;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x1dcab0d0_0, 0, 1;
    %jmp T_0.6;
T_0.4 ;
    %load/vec4 v0x1dc6f760_0;
    %inv;
    %store/vec4 v0x1dcab1a0_0, 0, 4;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x1dcab0d0_0, 0, 1;
    %jmp T_0.6;
T_0.6 ;
    %pop/vec4 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x1dc97350;
T_1 ;
    %vpi_call/w 3 19 "$display", "A B sel | result carry" {0 0 0};
    %pushi/vec4 5, 0, 4;
    %store/vec4 v0x1dcab450_0, 0, 4;
    %pushi/vec4 3, 0, 4;
    %store/vec4 v0x1dcab530_0, 0, 4;
    %pushi/vec4 0, 0, 3;
    %store/vec4 v0x1dcab7d0_0, 0, 3;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 3;
    %store/vec4 v0x1dcab7d0_0, 0, 3;
    %delay 10000, 0;
    %pushi/vec4 2, 0, 3;
    %store/vec4 v0x1dcab7d0_0, 0, 3;
    %delay 10000, 0;
    %pushi/vec4 3, 0, 3;
    %store/vec4 v0x1dcab7d0_0, 0, 3;
    %delay 10000, 0;
    %pushi/vec4 4, 0, 3;
    %store/vec4 v0x1dcab7d0_0, 0, 3;
    %delay 10000, 0;
    %vpi_call/w 3 41 "$finish" {0 0 0};
    %end;
    .thread T_1;
    .scope S_0x1dc97350;
T_2 ;
    %vpi_call/w 3 45 "$monitor", "%b %b %b | %b %b", v0x1dcab450_0, v0x1dcab530_0, v0x1dcab7d0_0, v0x1dcab700_0, v0x1dcab600_0 {0 0 0};
    %end;
    .thread T_2;
